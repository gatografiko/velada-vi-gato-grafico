---
import Layout from '../layouts/Layout.astro';

const bracketRows: { fighters: string[]; size: 1 | 2 | 3 }[] = [
  { fighters: ['GREFG', 'ALANA', 'PEREIRA'], size: 1 },
  { fighters: ['IBAI',  'GREFG'],             size: 1 },
  { fighters: ['ALANA'],                       size: 1 },
  { fighters: ['PEREIRA', 'IBAI'],             size: 1 },
  { fighters: ['GREFG', 'ALANA', 'PEREIRA'], size: 1 },
];

const fighterImage: Record<string, string> = {
  GREFG:   '/shadow.png',
  ALANA:   '/milena.png',
  PEREIRA: '/scorpion.png',
  IBAI:    '/shao-kan.png',
};

// object-position ajustado por personaje para mostrar cabeza/torso
const portraitPos: Record<string, string> = {
  GREFG:   '50% 0%',
  ALANA:   '50% 0%',
  PEREIRA: '50% 0%',
  IBAI:    '50% 0%',
};
---

<Layout>
  <div class="page">

    <!-- ── Nav ───────────────────────────────────── -->
    <nav class="nav">
      <span class="nav__brand">LA VELADA 2026</span>
      <ul class="nav__links">
        <li>COMPETICIONES</li>
        <li>PRONÓSTICOS</li>
        <li>TIENDA OFICIAL</li>
      </ul>
    </nav>

    <!-- ── Arena ─────────────────────────────────── -->
    <main class="arena">

      <!-- Fighter izquierda -->
      <section class="fighter fighter--left">
        <img src="/scorpion.png" alt="Pereira" class="fighter__img fighter__img--pereira" />
        <div class="fighter__info fighter__info--left">
          <h1 class="fighter__name">PEREIRA</h1>
          <span class="fighter__record">2-4-11</span>
          <img src="/españa.png" alt="España" class="fighter__flag" />
        </div>
      </section>

      <!-- Bracket hexagonal -->
      <div class="bracket">
        {bracketRows.map((row) => (
          <>
            <div class="bracket__row">
              {row.fighters.map(name => (
                <div class="hex-wrap" data-fighter={name}>
                  <div class="hex"></div>
                  <img
                    src={fighterImage[name]}
                    alt={name}
                    class="hex__portrait"
                    style={`object-position: ${portraitPos[name]}`}
                  />
                  <span class="hex__label">{name}</span>
                </div>
              ))}
            </div>
          </>
        ))}
      </div>

      <!-- Fighter derecha -->
      <section class="fighter fighter--right">
        <img src="/shao-kan.png" alt="Ibai" class="fighter__img fighter__img--shao-kan" />
        <div class="fighter__info fighter__info--right">
          <h1 class="fighter__name">IBAI</h1>
          <span class="fighter__record">2-4-11</span>
          <img src="/españa.png" alt="España" class="fighter__flag" />
        </div>
      </section>

      <!-- ══════════════════════════════════════════
           MÓVIL: layout completo (oculto en escritorio)
           ══════════════════════════════════════════ -->
      <div class="mobile-layout">

        <!-- Fighter principal -->
        <div class="mobile-fighter">
          <img src="/scorpion.png" alt="Pereira" class="mobile-fighter__img" />
          <div class="mobile-fighter__info">
            <h1 class="mobile-fighter__name">PEREIRA</h1>
            <span class="mobile-fighter__record">2-4-11</span>
            <img src="/españa.png" alt="España" class="mobile-fighter__flag" />
          </div>
        </div>

        <!-- Bracket 2×2 -->
        <div class="mobile-bracket">
          <div class="mobile-bracket__row">
            <div class="m-hex-wrap m-hex-wrap--active" data-fighter="PEREIRA">
              <div class="m-hex"></div>
              <img src="/scorpion.png" alt="Pereira" class="m-hex__portrait" style="object-position: 50% 0%" />
              <span class="m-hex__label">PEREIRA</span>
            </div>
            <div class="m-hex-wrap" data-fighter="ALANA">
              <div class="m-hex"></div>
              <img src="/milena.png" alt="Alana" class="m-hex__portrait" style="object-position: 50% 0%" />
              <span class="m-hex__label">ALANA</span>
            </div>
          </div>
          <div class="mobile-bracket__row">
            <div class="m-hex-wrap" data-fighter="GREFG">
              <div class="m-hex"></div>
              <img src="/shadow.png" alt="Grefg" class="m-hex__portrait" style="object-position: 50% 0%" />
              <span class="m-hex__label">GREFG</span>
            </div>
            <div class="m-hex-wrap" data-fighter="IBAI">
              <div class="m-hex"></div>
              <img src="/shao-kan.png" alt="Ibai" class="m-hex__portrait" style="object-position: 50% 0%" />
              <span class="m-hex__label">IBAI</span>
            </div>
          </div>
        </div>

      </div>

    </main>
  </div>
</Layout>

<script>
  const FIGHTERS: Record<string, { img: string; name: string }> = {
    PEREIRA: { img: '/scorpion.png',  name: 'PEREIRA' },
    IBAI:    { img: '/shao-kan.png',  name: 'IBAI'    },
    GREFG:   { img: '/shadow.png',   name: 'GREFG'   },
    ALANA:   { img: '/milena.png',   name: 'ALANA'   },
  };

  const ALL = Object.keys(FIGHTERS);

  // Escritorio
  const leftImg  = document.querySelector<HTMLImageElement>('.fighter--left  .fighter__img');
  const rightImg = document.querySelector<HTMLImageElement>('.fighter--right .fighter__img');
  const leftName  = document.querySelector<HTMLElement>('.fighter--left  .fighter__name');
  const rightName = document.querySelector<HTMLElement>('.fighter--right .fighter__name');

  // Móvil
  const mobileImg  = document.querySelector<HTMLImageElement>('.mobile-fighter__img');
  const mobileName = document.querySelector<HTMLElement>('.mobile-fighter__name');

  const DEFAULT_LEFT  = 'PEREIRA';
  const DEFAULT_RIGHT = 'IBAI';

  function randomOther(exclude: string): string {
    const pool = ALL.filter(f => f !== exclude);
    return pool[Math.floor(Math.random() * pool.length)];
  }

  function applyFighter(img: HTMLImageElement | null, nameEl: HTMLElement | null, key: string) {
    const data = FIGHTERS[key];
    if (!data || !img) return;
    img.style.opacity = '0';
    setTimeout(() => {
      img.src = data.img;
      img.alt = data.name;
      img.style.opacity = '1';
    }, 150);
    if (nameEl) nameEl.textContent = data.name;
  }

  const isMobile = () => window.innerWidth < 1024;

  document.querySelectorAll<HTMLElement>('[data-fighter]').forEach(wrap => {
    wrap.addEventListener('mouseenter', () => {
      const fighter = wrap.dataset.fighter!;
      const opponent = randomOther(fighter);

      if (isMobile()) {
        applyFighter(mobileImg, mobileName, fighter);
      } else {
        applyFighter(leftImg,  leftName,  fighter);
        applyFighter(rightImg, rightName, opponent);
      }
    });

    wrap.addEventListener('mouseleave', () => {
      if (isMobile()) {
        applyFighter(mobileImg, mobileName, DEFAULT_LEFT);
      } else {
        applyFighter(leftImg,  leftName,  DEFAULT_LEFT);
        applyFighter(rightImg, rightName, DEFAULT_RIGHT);
      }
    });
  });
</script>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ── Nav ─────────────────────────────────────── */
  .nav {
    display: flex;
    align-items: center;
    padding: 1rem 3rem;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav__brand { color: #f5c200; margin-right: auto; }
  .nav__links {
    display: flex;
    gap: 3.5rem;
    list-style: none;
    opacity: 0.72;
  }
  .nav__links li { cursor: pointer; transition: color 0.2s, opacity 0.2s; }
  .nav__links li:hover { opacity: 1; color: #f5c200; }

  /* ── Arena ──────────────────────────────────── */
  .arena {
    flex: 1;
    display: grid;
    grid-template-columns: 28% 44% 28%;
    min-height: calc(100vh - 50px);
    overflow: hidden;
  }

  /* ── Fighters ────────────────────────────────── */
  .fighter {
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: visible;
  }

  .fighter__img {
    position: absolute;
    bottom: 0;
    height: 100%;
    width: auto;
    object-fit: contain;
    object-position: bottom;
  }

  /* Scorpion: desvanece borde derecho y parte superior */
  .fighter__img--pereira {
    left: 0px;
  }

  /* GrefG: volteado para mirar al centro, desvanece borde izquierdo */
  .fighter__img--shao-kan {
    right: 20%;
    /* Girar horizontal 
    transform: scaleX(-1); */
    height: 100%;
  }

  .fighter__info--left {
    position: relative;
    z-index: 2;
    padding: 0 2rem 2.5rem 10rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .fighter__info--right {
    position: relative;
    z-index: 2;
    padding: 0 0 2.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-left: -60px;
  }
  .fighter__info--left  { align-items: center; }
  .fighter__info--right { align-items: center; }

  .fighter__name {
    font-size: clamp(8rem, 5.8vw, 7rem);
    letter-spacing: 0.01em;
    text-shadow: 0 0 50px #000, 0 0 18px #000, 2px 2px 0 rgba(0,0,0,0.6);
  }

  .fighter__record {
    display: inline-block;
    background: #f5c200;
    width: 12rem;
    color: #000;
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    text-align: center;
    border-radius: 4px;
    margin-top: -2rem;
  }

  .fighter__flag {
    width: 82px;
    height: auto;
    margin-top: -1rem;
  }

  /* ── Bracket ─────────────────────────────────── */
  .bracket {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .bracket__row {
    display: flex;
    gap: 40px;
    justify-content: center;
  }

  /* ── Hexágonos ───────────────────────────────── */
  /*  hex-wrap tiene ancho fijo = unidad base del grid del bracket. */
  .hex-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    width: 130px;
    padding-top: 5px; /* espacio sobre el hex para que el retrato sobresalga */
  }

  /* Capa exterior dorada */
  .hex {
    width: 130px;
    height: 114px;
    position: relative;
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    background: linear-gradient(90deg, #ffe500 0%, #e38000 48%);
    rotate: 90deg;
    transition: background 0.25s ease;
  }

  /* Hex se vuelve rojo al hacer hover */
  .hex-wrap:hover .hex {
    background: linear-gradient(90deg, #d41212 0%, #7a0000 48%);
  }

  /* Capa de glow: detrás del hex, blur libre */
  .hex-wrap {
    cursor: pointer;
  }

  .hex-wrap::after {
    content: '';
    position: absolute;
    top: 5px;
    left: 0;
    width: 130px;
    height: 114px;
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    rotate: 90deg;
    background: #d41212;
    z-index: -1;
    opacity: 0;
    scale: 1.15;
    filter: blur(10px);
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .hex-wrap:hover::after {
    opacity: 1;
  }

  /* Las imágenes de los fighters NO interceptan eventos del bracket */
  .fighter__img {
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  /* Retrato fuera del hex: cabeza y torso sobresalen por encima */
  .hex__portrait {
    position: absolute;
    top: 0;
    left: 50%;
    top: -10%;
    transform: translateX(-50%);
    height: 100%;   /* cabeza + torso únicamente */
    width: 100%;
    object-fit: cover;
    z-index: 2;      /* por encima del hex */
  }

  .hex__label {
    margin-top: -2rem;
    font-size: 2rem;
    color: #fff;
    font-style: italic;
    text-shadow: 1px 1px 5px rgba(0,0,0,1);
    text-align: center;
    line-height: 1;
    position: relative;
  }

  /* ══════════════════════════════════════════════
     MÓVIL  (< 1024 px)
     La vista escritorio se mantiene intacta en lg+
     ══════════════════════════════════════════════ */

  /* Ocultar layout móvil en escritorio */
  .mobile-layout {
    display: none;
  }

  @media (max-width: 1023px) {

    /* Nav simplificado */
    .nav {
      padding: 0.75rem 1.25rem;
    }
    .nav__links {
      display: none;
    }

    /* Arena: ocultar columnas escritorio, ceder espacio al layout móvil */
    .arena {
      display: block;
      min-height: calc(100vh - 48px);
      position: relative;
    }

    .fighter--left,
    .fighter--right,
    .bracket {
      display: none;
    }

    /* ── Contenedor móvil principal ── */
    .mobile-layout {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 48px);
    }

    /* ── Sección fighter: ancho completo, altura fija ── */
    .mobile-fighter {
      flex: 0 0 70vh;
      position: relative;
      overflow: hidden;
    }

    /* Imagen a full-width, recortada desde arriba */
    .mobile-fighter__img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }

    /* Info pegada al borde inferior de la imagen */
    .mobile-fighter__info {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      padding-bottom: 0.9rem;
    }

    .mobile-fighter__name {
      font-size: clamp(4rem, 19vw, 6.5rem);
      letter-spacing: 0.01em;
      font-style: italic;
      text-shadow:
        0 0 80px #000,
        0 0 30px #000,
        0 0 10px #000,
        3px 3px 0 rgba(0,0,0,0.8);
    }

    .mobile-fighter__record {
      display: inline-block;
      background: #f5c200;
      color: #000;
      font-size: 1.05rem;
      letter-spacing: 0.12em;
      text-align: center;
      border-radius: 3px;
      padding: 0.1rem 2rem;
      margin-top: -1.4rem;
    }

    .mobile-fighter__flag {
      width: 62px;
      height: auto;
      margin-top: 0.1rem;
    }

    /* ── Bracket 2×2: ocupa el espacio restante ── */
    .mobile-bracket {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.4rem 0 1rem;
      background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.92) 25%);
    }

    /* Fila 1: PEREIRA + ALANA — centrados con separación amplia */
    .mobile-bracket__row:first-child {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      margin-top: -15%;
      gap: 9.5rem;
      width: 100%;
    }

    /* Fila 2: GREFG + IBAI — centrada y más pequeña */
    .mobile-bracket__row:last-child {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: 3rem;
    }

    /* ── Hexágonos fila 1 (grandes) ── */
    .m-hex-wrap {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      width: 120px;
      padding-top: 10px;
    }

    .m-hex {
      width: 120px;
      height: 104px;
      clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
      background: linear-gradient(90deg, #ffe500 0%, #e38000 48%);
      rotate: 90deg;
      transition: background 0.25s ease;
    }

    /* Hexágono activo por defecto: rojo */
    .m-hex-wrap--active .m-hex {
      background: linear-gradient(90deg, #d41212 0%, #7a0000 48%);
    }

    /* Todos los hex se vuelven rojos al hacer hover */
    .m-hex-wrap:hover .m-hex {
      background: linear-gradient(90deg, #d41212 0%, #7a0000 48%);
    }

    /* Capa de glow para todos los m-hex-wrap */
    .m-hex-wrap {
      cursor: pointer;
    }

    .m-hex-wrap::after {
      content: '';
      position: absolute;
      top: 10px;
      left: 0;
      width: 120px;
      height: 104px;
      clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
      rotate: 90deg;
      background: #d41212;
      z-index: -1;
      opacity: 0;
      scale: 1.18;
      filter: blur(10px);
      transition: opacity 0.3s ease;
      pointer-events: none;
    }

    .m-hex-wrap:hover::after {
      opacity: 1;
    }

    /* Ajuste del ::after para hexágonos pequeños (fila 2) */
    .mobile-bracket__row:last-child .m-hex-wrap::after {
      width: 88px;
      height: 77px;
      top: 7px;
    }

    /* Imagen del fighter central: transición suave al cambiar */
    .mobile-fighter__img {
      transition: opacity 0.2s ease;
    }

    .m-hex__portrait {
      position: absolute;
      top: -14%;
      left: 50%;
      transform: translateX(-50%);
      height: 116%;
      width: 100%;
      object-fit: cover;
      z-index: 2;
    }

    .m-hex__label {
      margin-top: -1.8rem;
      font-size: 1.15rem;
      color: #fff;
      font-style: italic;
      text-shadow: 1px 1px 6px rgba(0,0,0,1);
      text-align: center;
      line-height: 1;
      position: relative;
      z-index: 3;
    }

    /* ── Hexágonos fila 2 (pequeños) ── */
    .mobile-bracket__row:last-child .m-hex-wrap {
      width: 88px;
      padding-top: 7px;
    }

    .mobile-bracket__row:last-child .m-hex {
      width: 88px;
      height: 77px;
    }

    .mobile-bracket__row:last-child .m-hex__label {
      font-size: 0.88rem;
      margin-top: -1.3rem;
    }
  }
</style>
